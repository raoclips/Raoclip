<!-- RaoEstate.in - Property Listing Website (Admin-only with Admin Panel Upload) --><!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RaoEstate.in - Property Listings</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-100 text-gray-900">
  <header class="bg-white shadow p-4 flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold">RaoEstate.in</h1>
      <p class="text-sm text-gray-500">Verified Properties in Agra, Firozabad, Mainpuri, Etah & More</p>
    </div>
    <button onclick="toggleForm()" class="bg-green-600 text-white px-4 py-2 rounded">+ Add Property</button>
  </header>  <!-- Admin Upload Form (Hidden by default) -->  <section id="uploadForm" class="max-w-3xl mx-auto mt-4 bg-white p-4 shadow rounded hidden">
    <h2 class="text-lg font-semibold mb-2">Upload New Property</h2>
    <form id="propertyForm" class="space-y-3">
      <input type="text" id="title" placeholder="Property Title" class="w-full border p-2 rounded" required>
      <input type="text" id="city" placeholder="City" class="w-full border p-2 rounded" required>
      <input type="text" id="price" placeholder="Price" class="w-full border p-2 rounded" required>
      <input type="text" id="img" placeholder="Image URL (e.g., from Imgur)" class="w-full border p-2 rounded" required>
      <input type="text" id="contact" placeholder="Contact Number" class="w-full border p-2 rounded" required>
      <input type="text" id="whatsapp" placeholder="WhatsApp Number" class="w-full border p-2 rounded" required>
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Submit</button>
    </form>
  </section>  <main class="p-4 max-w-5xl mx-auto">
    <div id="property-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    </div>
  </main>  <footer class="text-center text-gray-500 text-sm py-4">
    &copy; 2025 RaoEstate.in. All rights reserved.
  </footer>  <script>
    let properties = JSON.parse(localStorage.getItem('properties')) || [
      {
        title: "Residential Plot in Agra",
        city: "Agra",
        price: "Rs. 12,00,000",
        img: "https://via.placeholder.com/400x250",
        contact: "9105327034",
        whatsapp: "9105327034"
      }
    ];

    const container = document.getElementById('property-list');
    function renderProperties() {
      container.innerHTML = '';
      properties.forEach(p => {
        const card = document.createElement('div');
        card.className = "bg-white rounded-lg shadow-md overflow-hidden";
        card.innerHTML = `
          <img src="${p.img}" class="w-full h-48 object-cover" />
          <div class="p-4">
            <h3 class="text-lg font-bold">${p.title}</h3>
            <p class="text-sm text-gray-500">${p.city}</p>
            <p class="text-green-600 font-semibold">${p.price}</p>
            <div class="mt-3">
              <a href="tel:${p.contact}" class="inline-block bg-blue-600 text-white px-3 py-1 rounded mr-2">Call Now</a>
              <a href="https://wa.me/91${p.whatsapp}" class="inline-block bg-green-600 text-white px-3 py-1 rounded">WhatsApp</a>
            </div>
          </div>
        `;
        container.appendChild(card);
      });
    }
    renderProperties();

    function toggleForm() {
      document.getElementById('uploadForm').classList.toggle('hidden');
    }

    document.getElementById('propertyForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const newProp = {
        title: document.getElementById('title').value,
        city: document.getElementById('city').value,
        price: document.getElementById('price').value,
        img: document.getElementById('img').value,
        contact: document.getElementById('contact').value,
        whatsapp: document.getElementById('whatsapp').value
      };
      properties.push(newProp);
      localStorage.setItem('properties', JSON.stringify(properties));
      renderProperties();
      this.reset();
      toggleForm();
    });
  </script></body>
</html>